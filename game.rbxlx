        <string name="Name">Enums</string>
        <string name="Source"><![CDATA[local Enums = {}

Enums.SkillId = {
	Slash = "Slash",
	Fireball = "Fireball",
	Heal = "Heal",
	Shield = "Shield",
}

Enums.EnemyId = {
	Skeleton = "Skeleton",
	Zombie = "Zombie",
	Archer = "Archer",
	BossGolem = "BossGolem",
}

Enums.ItemId = {
	IronSword = "IronSword",
	HealthAmulet = "HealthAmulet",
	MageRing = "MageRing",
	ShieldCharm = "ShieldCharm",
	SpeedBoots = "SpeedBoots",
	BossLegendary = "BossLegendary",
}

Enums.RoomState = {
	Locked = "Locked",
	Active = "Active",
	Cleared = "Cleared",
}

return Enums
