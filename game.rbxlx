      <Item class="ModuleScript" referent="7">
        <Properties>
          <string name="Name">SkillConfig</string>
          <string name="Source"><![CDATA[local SkillConfig = {}

-- Weapons are items the player equips. Each has an ability.
-- Press 1-4 to switch weapon, click to use it.
SkillConfig.Weapons = {
	Sword = {
		Name = "Iron Sword",
		Slot = 1,
		ManaCost = 0,
