	{
		Name        = "Mage Tower",
		Type        = "miniboss",
		FolderPath  = "RoomTemplates/MageTower",
		Description = "The Emerald Warden controls the arcane wards of this sorcerer's spire.",
		Difficulty  = 4,
		DropsKey    = "Emerald",
