		DefenseBonus = 50,
		Duration = 5.0,
		Description = "+50 Defense for 5s",
		Color = Color3.fromRGB(50, 150, 255),
	},
}

-- Map slot numbers to weapon IDs
SkillConfig.SlotToWeapon = {
	[1] = "Sword",
	[2] = "Staff",
	[3] = "Wand",
	[4] = "Shield",
}

-- Keep backward compat: Skills table maps weapon IDs to their data
