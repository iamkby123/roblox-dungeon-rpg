	-- ===== INFO SIGNS (wooden, near campsite) =====
	-- Controls sign post (left of camp)
	mp({Size=Vector3.new(2, 6, 2), Position=Vector3.new(-18, 3.5, 8),
		Material=Enum.Material.Wood, BrickColor=BrickColor.new("Dark orange")})
	makeSign(
